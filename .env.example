# Install as $XDG_CONFIG_HOME/ecoesp/.env (normally
# ~/.config/ecoesp/.env) and fill it in. The project directory is not read.

# One or more Gemini API keys, comma-separated
# (https://aistudio.google.com/apikey). Keys from different projects have
# independent quota and can participate in parallel TTS generation.
GEMINI_API_KEY=your-first-key,your-second-key,your-third-key

# Account that receives the forwarded Economist emails (reads + sends).
READER_EMAIL=reader@example.com
# Account the translated email is delivered to.
DEST_EMAIL=you@example.com

# Gmail search that selects the source newsletter.
GMAIL_QUERY=from:noreply@e.economist.com subject:"world in brief"

# Optional: where app files live. Defaults follow the XDG base directories:
#   config: $XDG_CONFIG_HOME/ecoesp, or ~/.config/ecoesp
#   state:  $XDG_STATE_HOME/ecoesp, or ~/.local/state/ecoesp
#   cache:  $XDG_CACHE_HOME/ecoesp, or ~/.cache/ecoesp
#   data:   $XDG_DATA_HOME/ecoesp, or ~/.local/share/ecoesp
# ECOESP_STATE_DIR=/home/you/.local/state/ecoesp
# ECOESP_CACHE_DIR=/home/you/.cache/ecoesp
# ECOESP_DATA_DIR=/home/you/.local/share/ecoesp
# ECOESP_CONFIG_DIR must be set by the launching process because it controls
# where this .env file is loaded from.
# ECOESP_CONFIG_DIR=/home/you/.config/ecoesp
# Optional: override only the Google OAuth client file location.
# GOOGLE_CREDENTIALS_PATH=/home/you/.config/ecoesp/credentials.json

# Optional overrides (comma-separated model fallback chains, TTS tuning):
# TEXT_MODELS=gemini-3.5-flash,gemini-3-flash-preview,gemini-2.5-flash
# TTS_MODELS=gemini-3.1-flash-tts-preview,gemini-2.5-flash-preview-tts
# TTS_VOICE=Kore
# GEMINI_TIMEOUT_MS=180000

# Optional: silence in the recording, in seconds. SEGMENT_GAP_SECONDS separates
# the readings within one story; BULLET_GAP_SECONDS separates one story from the
# next. 0 turns a gap off.
# SEGMENT_GAP_SECONDS=0.8
# BULLET_GAP_SECONDS=1.2

# Optional: prepended to the subject of the email sent back. Empty leaves the
# original subject unchanged.
# SUBJECT_PREFIX=[译]

# Optional: files you can drop in to override what ships with the app.
#   ~/.config/ecoesp/prompts/<name>.md  replaces a bundled prompt, e.g.
#       tts_original.md, tts_vocab.md, tts_translation.md, text_translation.md,
#       text_vocab.md. Keep the markdown headings the shipped prompt produces
#       (## 一, #### 原文, #### 中文翻译, #### 生词注释) — the audio pipeline
#       parses them.
#   ~/.config/ecoesp/email.html        replaces the email template ({body}
#       is substituted with the rendered story).
#   ~/.local/share/ecoesp/opening.pcm  a personal opening jingle, played
#       before the first story (24kHz 16-bit mono raw PCM).
